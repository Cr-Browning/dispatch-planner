# Copy to backend/.env and adjust before running locally.
# Paths below are relative to dispatch-planner/ (repo root), not backend/.

# Required — change in any shared or deployed environment
APP_SECRET_KEY=change-me-in-production
DISPATCHER_PASSWORD=changeme

# SQLite database file (created on first run)
DATABASE_URL=sqlite:///./data/dispatch.db

# Writable directories for exports and future backup jobs
EXPORT_DIR=./exports
BACKUP_DIR=./backups

# Routing: mock (default, no API key) or google (live Maps APIs)
ROUTING_PROVIDER=mock
GOOGLE_MAPS_API_KEY=

# Copy SQLite DB to BACKUP_DIR on API startup (recommended for production)
BACKUP_ON_STARTUP=false

# Optional: not required for local dev (defaults shown in config.py)
# ACCESS_TOKEN_EXPIRE_MINUTES=720
